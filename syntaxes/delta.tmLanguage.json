{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Delta",
  "scopeName": "text.xml.delta",
  "patterns": [{ "include": "#content" }],
  "repository": {
    "content": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#cdata" },
        { "include": "#raw-elements" },
        { "include": "#math-element" },
        { "include": "#styled-elements" },
        { "include": "#tags" },
        { "include": "#escaped-dollar" },
        { "include": "#math-block" },
        { "include": "#math-inline" },
        { "include": "#entities" }
      ]
    },
    "comments": {
      "name": "comment.block.delta",
      "begin": "<!--",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.delta" }
      },
      "end": "-->",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.delta" }
      }
    },
    "cdata": {
      "name": "string.unquoted.cdata.delta",
      "begin": "<!\\[CDATA\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.tag.begin.delta" }
      },
      "end": "\\]\\]>",
      "endCaptures": {
        "0": { "name": "punctuation.definition.tag.end.delta" }
      }
    },
    "entities": {
      "name": "constant.character.entity.delta",
      "match": "&(?:#[0-9]+|#x[0-9a-fA-F]+|[a-zA-Z][a-zA-Z0-9]*);"
    },
    "escaped-dollar": {
      "name": "constant.character.escape.delta",
      "match": "\\\\\\$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.delta",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.delta" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.delta" }
          },
          "patterns": [{ "include": "#entities" }]
        },
        {
          "name": "string.quoted.single.delta",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.delta" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.delta" }
          },
          "patterns": [{ "include": "#entities" }]
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        {
          "match": "([_:a-zA-Z][-_:.a-zA-Z0-9]*)\\s*(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.delta" },
            "2": { "name": "punctuation.separator.key-value.delta" }
          }
        },
        { "include": "#strings" }
      ]
    },
    "tags": {
      "name": "meta.tag.delta",
      "begin": "(</?)([_:a-zA-Z][-_:.a-zA-Z0-9]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.delta" }
      },
      "patterns": [{ "include": "#tag-attributes" }]
    },
    "math-element": {
      "name": "meta.tag.math.delta",
      "begin": "(<)(equations|equation|m)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(equations|equation|m)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "meta.embedded.math.delta markup.math.delta",
      "patterns": [{ "include": "#math-content" }]
    },
    "raw-elements": {
      "patterns": [
        {
          "begin": "(<)(code|c)((?:\\s+[^<>]*?)?)(?<!/)(>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.delta" },
            "2": { "name": "entity.name.tag.delta" },
            "3": { "patterns": [{ "include": "#tag-attributes" }] },
            "4": { "name": "punctuation.definition.tag.end.delta" }
          },
          "end": "(</)(code|c)\\s*(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.delta" },
            "2": { "name": "entity.name.tag.delta" },
            "3": { "name": "punctuation.definition.tag.end.delta" }
          },
          "contentName": "markup.inline.raw.delta",
          "patterns": [{ "include": "#entities" }]
        }
      ]
    },
    "styled-elements": {
      "patterns": [
        { "include": "#heading-element" },
        { "include": "#italic-element" },
        { "include": "#bold-element" },
        { "include": "#mark-element" },
        { "include": "#intro-element" }
      ]
    },
    "heading-element": {
      "begin": "(<)(title)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(title)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "markup.heading.delta",
      "patterns": [{ "include": "#content" }]
    },
    "italic-element": {
      "begin": "(<)(em|i)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(em|i)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "markup.italic.delta",
      "patterns": [{ "include": "#content" }]
    },
    "bold-element": {
      "begin": "(<)(b)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(b)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "markup.bold.delta",
      "patterns": [{ "include": "#content" }]
    },
    "mark-element": {
      "begin": "(<)(mark)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(mark)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "markup.highlight.delta",
      "patterns": [{ "include": "#content" }]
    },
    "intro-element": {
      "begin": "(<)(intro)((?:\\s+[^<>]*?)?)(?<!/)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.delta" }
      },
      "end": "(</)(intro)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.delta" },
        "2": { "name": "entity.name.tag.delta" },
        "3": { "name": "punctuation.definition.tag.end.delta" }
      },
      "contentName": "markup.quote.delta",
      "patterns": [{ "include": "#content" }]
    },
    "math-block": {
      "name": "meta.embedded.math.block.delta markup.math.block.delta",
      "begin": "(?<!\\\\)(\\$\\$)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.math.begin.delta" }
      },
      "end": "(\\$\\$)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.math.end.delta" }
      },
      "patterns": [{ "include": "#math-content" }]
    },
    "math-inline": {
      "name": "meta.embedded.math.inline.delta markup.math.inline.delta",
      "begin": "(?<!\\\\)(\\$)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.math.begin.delta" }
      },
      "end": "(?<!\\\\)(\\$)|$",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.math.end.delta" }
      },
      "patterns": [{ "include": "#math-content" }]
    },
    "math-content": {
      "patterns": [
        { "include": "#escaped-dollar" },
        {
          "name": "constant.character.escape.delta",
          "match": "\\\\[\\\\{}$&%#_^~]"
        },
        {
          "name": "support.function.delta",
          "match": "\\\\[a-zA-Z@]+"
        },
        {
          "name": "keyword.operator.math.delta",
          "match": "[\\^_]"
        },
        {
          "name": "punctuation.definition.group.delta",
          "match": "[{}]"
        },
        {
          "name": "comment.line.percentage.delta",
          "match": "%.*$"
        }
      ]
    }
  }
}
